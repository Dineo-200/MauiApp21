<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiApp21.forgetpassword"
             Title="forgetpassword">
    <Grid RowDefinitions="*,Auto">
        
        <!--Client Details-->
        <ListView Grid.Row="0"
                  x:Name="DisplayInformation"
                  ItemsSource="{Binding ClientDetails}"
                  HasUnevenRows="True"
                  ItemTapped="DisplayInformation_ItemTapped">

            <ListView.ItemTemplate>
                <DataTemplate>
                    <ViewCell>
                        <VerticalStackLayout Padding="10">
                            <Label Text="{Binding Name}" FontAttributes="Bold"/>
                            <Label Text="{Binding Email}" FontAttributes="Bold"/>
                            <Label Text="{Binding Password}" FontAttributes="Bold"/>
                        </VerticalStackLayout> 
                    </ViewCell>
                </DataTemplate>
            </ListView.ItemTemplate>
                  
            
        </ListView>
        <!--edit,delete and save-->
        <VerticalStackLayout>
            <Entry Placeholder="Name" x:Name="NameEntryField" Text="{Binding Name}"/>
            <Entry Placeholder="Email" x:Name="EmailEntryField" Text="{Binding Email}"/>
            <Entry Placeholder="Password" x:Name="PasswordEntryField" Text="{Binding Password}"/>
            <Button Text="Save" x:Name="SaveButton" Command="{Binding SaveEditCommand}"/>
        </VerticalStackLayout>

    </Grid>
</ContentPage>