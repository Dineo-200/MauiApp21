<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiApp21.CreateAccount"
             Title="CreateAccount">
    <VerticalStackLayout Padding="10" BackgroundColor="Teal">
        <Entry Text="{Binding Name}" x:Name="NameEntryField" Placeholder="Name"/>
        <Entry Text="{Binding Email}" x:Name="EmailEntryField" Placeholder="Email"/>
       <Entry Text="{Binding Password}" IsPassword="True" x:Name="PasswordEntryField" Placeholder="Password"/>
       <Button Text="save" x:Name="SaveButton" Command="{Binding SaveCommand}"/>
    </VerticalStackLayout>
</ContentPage>